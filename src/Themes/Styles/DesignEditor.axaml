<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:ArxisStudio"
                    xmlns:controls="clr-namespace:ArxisStudio.Controls"
                    xmlns:helpers="clr-namespace:ArxisStudio.Helpers">

    <helpers:UnscaleTransformConverter x:Key="UnscaleTransformConverter" />
    <helpers:ScaleDoubleConverter x:Key="ScaleDoubleConverter" />

    <ControlTheme x:Key="SelectionRectangleStyle" TargetType="Rectangle">
        <Setter Property="Stroke" Value="{DynamicResource DesignEditor.MarqueeStrokeBrush}" />
        <Setter Property="StrokeThickness" Value="{DynamicResource DesignEditor.Selection.StrokeThickness}" />
        <Setter Property="Fill" Value="{DynamicResource DesignEditor.MarqueeFillBrush}" />
        <Setter Property="IsHitTestVisible" Value="False"/>
    </ControlTheme>

    <ControlTheme x:Key="SelectionOutlineStyle"
                  TargetType="controls:SelectionAdorner"
                  BasedOn="{StaticResource {x:Type controls:SelectionAdorner}}">
        <Setter Property="AdornerBrush" Value="{DynamicResource DesignEditor.Selection.PrimaryBrush}" />
        <Setter Property="StrokeThickness" Value="{DynamicResource DesignEditor.Selection.StrokeThickness}" />
        <Setter Property="Fill" Value="{DynamicResource DesignEditor.SelectionAdorner.Fill}" />
        <Setter Property="ShowHandles" Value="True" />
        <Setter Property="IsInteractive" Value="True" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </ControlTheme>

    <ControlTheme x:Key="GroupSelectionOutlineStyle"
                  TargetType="controls:SelectionAdorner"
                  BasedOn="{StaticResource {x:Type controls:SelectionAdorner}}">
        <Setter Property="AdornerBrush" Value="{DynamicResource DesignEditor.Selection.GroupBrush}" />
        <Setter Property="StrokeThickness" Value="{DynamicResource DesignEditor.Selection.StrokeThickness}" />
        <Setter Property="StrokeDashArray" Value="4,2" />
        <Setter Property="Fill" Value="{DynamicResource DesignEditor.Selection.GroupFillBrush}" />
        <Setter Property="ShowHandles" Value="False" />
        <Setter Property="IsInteractive" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </ControlTheme>

    <ControlTheme x:Key="SecondarySelectionOutlineStyle"
                  TargetType="controls:SelectionAdorner"
                  BasedOn="{StaticResource {x:Type controls:SelectionAdorner}}">
        <Setter Property="AdornerBrush" Value="{DynamicResource DesignEditor.Selection.SecondaryBrush}" />
        <Setter Property="StrokeThickness" Value="{DynamicResource DesignEditor.Selection.StrokeThickness}" />
        <Setter Property="Fill" Value="{DynamicResource DesignEditor.SelectionAdorner.Fill}" />
        <Setter Property="ShowHandles" Value="False" />
        <Setter Property="IsInteractive" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </ControlTheme>

    <ControlTheme x:Key="{x:Type local:DesignEditor}" TargetType="local:DesignEditor">
        <Setter Property="Background" Value="{DynamicResource DesignEditor.BackgroundBrush}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="SelectionRectangleStyle" Value="{StaticResource SelectionRectangleStyle}" />
        <Setter Property="SelectionOutlineStyle" Value="{StaticResource SelectionOutlineStyle}" />
        <Setter Property="GroupSelectionOutlineStyle" Value="{StaticResource GroupSelectionOutlineStyle}" />
        <Setter Property="SecondarySelectionOutlineStyle" Value="{StaticResource SecondarySelectionOutlineStyle}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                    <Grid>
                        <Canvas Name="PART_ItemsLayer"
                                RenderTransform="{TemplateBinding ViewportTransform}"
                                RenderTransformOrigin="0,0">

                            <ItemsPresenter Name="PART_ItemsPresenter">
                                <ItemsPresenter.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:DesignSurface Extent="{Binding ItemsExtent, Mode=OneWayToSource, RelativeSource={RelativeSource AncestorType=local:DesignEditor}}" />
                                    </ItemsPanelTemplate>
                                </ItemsPresenter.ItemsPanel>
                            </ItemsPresenter>
                        </Canvas>

                        <Canvas Name="PART_SelectionOverlayLayer"
                                IsHitTestVisible="True"
                                RenderTransform="{TemplateBinding ViewportTransform}"
                                RenderTransformOrigin="0,0">
                            <controls:SelectionAdornerLayer Items="{TemplateBinding SecondarySelectionAdorners}"
                                                            AdornerTheme="{TemplateBinding SelectionOutlineStyle}"
                                                            ViewportZoom="{TemplateBinding ViewportZoom}"
                                                            ClipToBounds="False"
                                                            IsHitTestVisible="True"
                                                            IsVisible="{TemplateBinding HasMultipleNestedSelection}" />

                            <controls:SelectionAdorner Name="PART_SelectionAdorner"
                                                       Theme="{TemplateBinding SelectionOutlineStyle}"
                                                       Role="Primary"
                                                       ShowHandles="True"
                                                       IsInteractive="True"
                                                       RenderTransform="{Binding ViewportTransform, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource UnscaleTransformConverter}}"
                                                       RenderTransformOrigin="0,0"
                                                       Canvas.Top="{Binding SelectionBounds.Y, RelativeSource={RelativeSource TemplatedParent}}"
                                                       Canvas.Left="{Binding SelectionBounds.X, RelativeSource={RelativeSource TemplatedParent}}"
                                                       IsVisible="{TemplateBinding HasSingleSelection}"
                                                       IsHitTestVisible="True">
                                <controls:SelectionAdorner.Width>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectionBounds.Width" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </controls:SelectionAdorner.Width>
                                <controls:SelectionAdorner.Height>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectionBounds.Height" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </controls:SelectionAdorner.Height>
                            </controls:SelectionAdorner>

                            <controls:SelectionAdorner Name="PART_GroupSelectionAdorner"
                                                       Theme="{TemplateBinding GroupSelectionOutlineStyle}"
                                                       Role="Group"
                                                       ShowHandles="True"
                                                       IsInteractive="True"
                                                       RenderTransform="{Binding ViewportTransform, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource UnscaleTransformConverter}}"
                                                       RenderTransformOrigin="0,0"
                                                       Canvas.Top="{Binding SelectionBounds.Y, RelativeSource={RelativeSource TemplatedParent}}"
                                                       Canvas.Left="{Binding SelectionBounds.X, RelativeSource={RelativeSource TemplatedParent}}"
                                                       IsVisible="{TemplateBinding HasMultipleContainerSelection}"
                                                       IsHitTestVisible="True">
                                <controls:SelectionAdorner.Width>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectionBounds.Width" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </controls:SelectionAdorner.Width>
                                <controls:SelectionAdorner.Height>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectionBounds.Height" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </controls:SelectionAdorner.Height>
                            </controls:SelectionAdorner>
                        </Canvas>

                        <Canvas Name="PART_InteractionOverlayLayer"
                                IsHitTestVisible="False"
                                RenderTransform="{TemplateBinding ViewportTransform}"
                                RenderTransformOrigin="0,0">
                            <Rectangle Theme="{TemplateBinding SelectionRectangleStyle}"
                                       RenderTransform="{Binding ViewportTransform, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource UnscaleTransformConverter}}"
                                       RenderTransformOrigin="0,0"
                                       Canvas.Top="{Binding SelectedArea.Y, RelativeSource={RelativeSource TemplatedParent}}"
                                       Canvas.Left="{Binding SelectedArea.X, RelativeSource={RelativeSource TemplatedParent}}"
                                       IsVisible="{TemplateBinding IsSelecting}">
                                <Rectangle.Width>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectedArea.Width" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </Rectangle.Width>
                                <Rectangle.Height>
                                    <MultiBinding Converter="{StaticResource ScaleDoubleConverter}">
                                        <Binding Path="SelectedArea.Height" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ViewportZoom" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </Rectangle.Height>
                            </Rectangle>
                        </Canvas>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
