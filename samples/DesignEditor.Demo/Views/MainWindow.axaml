<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesignEditor.Demo.ViewModels"
        xmlns:templates="using:DesignEditor.Demo.Views.Templates"
        xmlns:arxisStudio="clr-namespace:ArxisStudio;assembly=ArxisStudio.DesignEditor"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="DesignEditor.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DesignEditor.Demo"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.toolBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.toolBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Window.Resources>
        <Color x:Key="BackgroundColor">#141417</Color>
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
        <SolidColorBrush x:Key="SmallLineBrush" Color="#26292E" />
        <SolidColorBrush x:Key="LargeLineBrush" Color="#3E4451" />

        <DrawingGroup x:Key="UnifiedGridDrawing">
            <GeometryDrawing Brush="{StaticResource BackgroundBrush}">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,100,100" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="{x:Null}">
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource SmallLineBrush}" Thickness="1" />
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <GeometryGroup>
                        <LineGeometry StartPoint="20,0" EndPoint="20,100" />
                        <LineGeometry StartPoint="40,0" EndPoint="40,100" />
                        <LineGeometry StartPoint="60,0" EndPoint="60,100" />
                        <LineGeometry StartPoint="80,0" EndPoint="80,100" />
                        <LineGeometry StartPoint="0,20" EndPoint="100,20" />
                        <LineGeometry StartPoint="0,40" EndPoint="100,40" />
                        <LineGeometry StartPoint="0,60" EndPoint="100,60" />
                        <LineGeometry StartPoint="0,80" EndPoint="100,80" />
                    </GeometryGroup>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="{x:Null}">
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource LargeLineBrush}" Thickness="1" />
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <StreamGeometry>M0,0 L100,0 M0,0 L0,100</StreamGeometry>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingGroup>

        <DrawingBrush x:Key="DesignEditorGridBrush"
                      TileMode="Tile"
                      DestinationRect="0 0 100 100"
                      Transform="{Binding DpiScaledViewportTransform, ElementName=Editor}"
                      Drawing="{StaticResource UnifiedGridDrawing}" />
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">

        <arxisStudio:DesignEditor x:Name="Editor"
                                 Background="{StaticResource DesignEditorGridBrush}"
                                 ItemsSource="{Binding Elements}"
                                 SelectedItems="{Binding SelectedElements}"
                                 SelectionMode="Multiple"
                                 ViewportZoom="{Binding Zoom, Mode=TwoWay}">
            <arxisStudio:DesignEditor.InputGestures>
                <arxisStudio:DesignEditorInputGestures PanButton="Middle"
                                                       PanModifiers="None"
                                                       MarqueeButton="Left"
                                                       MarqueeModifiers="None"
                                                       ZoomModifiers="None"
                                                       ContainerInteractionModifiers="Control"
                                                       AdditiveSelectionModifiers="Shift" />
            </arxisStudio:DesignEditor.InputGestures>
            <arxisStudio:DesignEditor.InteractionOptions>
                <arxisStudio:DesignEditorInteractionOptions ZoomStep="1.1"
                                                           DragStartThreshold="3"
                                                           ResizeMinSize="10" />
            </arxisStudio:DesignEditor.InteractionOptions>

            <arxisStudio:DesignEditor.DataTemplates>
                <DataTemplate DataType="{x:Type vm:LoginElementViewModel}">
                    <templates:LoginElementView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:DashboardElementViewModel}">
                    <templates:DashboardElementView />
                </DataTemplate>
            </arxisStudio:DesignEditor.DataTemplates>

        </arxisStudio:DesignEditor>

        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,10,0,0"
                Background="#CC1E1E1E"
                BorderBrush="#3E4451" BorderThickness="1"
                CornerRadius="8" Padding="5,0"
                BoxShadow="0 4 12 0 #66000000">

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" ToolTip.Tip="Selected Items">
                    <PathIcon Data="M12.5,17.5L17.5,12.5L12.5,12.5L12.5,17.5ZM6.5,7.5L6.5,12.5L11.5,12.5L6.5,7.5ZM19,3L19,9L21,9L21,3C21,1.9 20.1,1 19,1L13,1L13,3L19,3ZM3,21C3,22.1 3.9,23 5,23L11,23L11,21L5,21L5,15L3,15L3,21ZM3,9L5,9L5,3L11,3L11,1L5,1C3.9,1 3,1.9 3,3L3,9ZM21,15L19,15L19,21L13,21L13,23L19,23C20.1,23 21,22.1 21,21L21,15Z"
                              Width="14" Height="14" Foreground="#4C97FF"/>
                    <TextBlock Text="{Binding SelectedElements.Count, StringFormat='{}{0} items'}"
                               Foreground="White" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Opacity="0.9"
                            IsVisible="{Binding #Editor.PrimarySelectionTarget, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Target:"
                               Foreground="#666"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding #Editor.PrimarySelectionTarget.DisplayName}"
                               Foreground="#F6C768"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Targets:"
                               Foreground="#666"
                               FontSize="10"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding #Editor.SelectedDesignTargetsCount, StringFormat='{}{0}'}"
                               Foreground="#7EE787"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Height="16" Fill="#3E4451"/>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Opacity="0.9"
                            IsVisible="{Binding ActiveItem, Converter={x:Static ObjectConverters.IsNotNull}}">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M12,2L16,6H13V13H20V10L24,14L20,18V15H13V22H16L12,26L8,22H11V15H4V18L0,14L4,10V13H11V6H8L12,2Z"
                                  Width="12" Height="12" Foreground="#999" ToolTip.Tip="Position"/>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="X" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveItem.X, StringFormat='{}{0:0}'}"
                                       Foreground="#CCC" FontSize="12" Width="30" FontFamily="Consolas, Monospace"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Y" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveItem.Y, StringFormat='{}{0:0}'}"
                                       Foreground="#CCC" FontSize="12" Width="30" FontFamily="Consolas, Monospace"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Width="1" Height="10" Fill="#3E4451" Opacity="0.5"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M2,6V8H5V6H2M2,10V12H5V10H2M2,14V16H5V14H2M2,18V20H5V18H2M6,2V22H18V2H6M16,6V8H8V6H16M16,10V12H8V10H16M16,14V16H8V14H16M16,18V20H8V18H16M20,6V8H22V6H20M20,10V12H22V10H20M20,14V16H22V14H20M20,18V20H22V18H20Z"
                                  Width="12" Height="12" Foreground="#999" ToolTip.Tip="Size"/>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="W" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveItem.Width, StringFormat='{}{0:F0}'}"
                                       Foreground="#CCC" FontSize="12" Width="30" FontFamily="Consolas, Monospace"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="H" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveItem.Height, StringFormat='{}{0:F0}'}"
                                       Foreground="#CCC" FontSize="12" Width="30" FontFamily="Consolas, Monospace"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <Rectangle Width="1" Height="16" Fill="#3E4451"/>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Opacity="0.5">
                    <TextBlock Text="Viewport:" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding #Editor.ViewportLocation.X, StringFormat='{}{0:0}'}" Foreground="#999" FontSize="10"/>
                    <TextBlock Text="{Binding #Editor.ViewportLocation.Y, StringFormat='{}{0:0}'}" Foreground="#999" FontSize="10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <PathIcon Data="M15.5,14L14.71,14L14.43,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71L14,15.5L19,20.5L20.5,19L15.5,14M9.5,14C7.01,14 5,11.99 5,9.5C5,7.01 7.01,5 9.5,5C11.99,5 14,7.01 14,9.5C14,11.99 11.99,14 9.5,14Z"
                              Width="14" Height="14" Foreground="#999"/>

                    <Slider Width="80" VerticalAlignment="Center"
                            Minimum="{Binding #Editor.MinZoom}"
                            Maximum="{Binding #Editor.MaxZoom}"
                            Value="{Binding #Editor.ViewportZoom}"
                            TickFrequency="0.1" IsSnapToTickEnabled="False"/>

                    <Button Classes="toolBtn" ToolTip.Tip="Reset Zoom (100%)"
                            Command="{Binding ResetZoomCommand}"
                            Padding="4,2">
                        <TextBlock Text="{Binding #Editor.ViewportZoom, StringFormat='{}{0:P0}'}"
                                   Foreground="White" FontSize="11" Width="35" TextAlignment="Center"/>
                    </Button>
                </StackPanel>

                <Button Classes="toolBtn"
                        ToolTip.Tip="Center active item in view"
                        Click="CenterActiveItem_OnClick"
                        IsVisible="{Binding ActiveItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M12,2A10,10 0 0 1 22,12A10,10 0 0 1 12,22A10,10 0 0 1 2,12A10,10 0 0 1 12,2M11,7V11H7V13H11V17H13V13H17V11H13V7H11Z"
                                  Width="14"
                                  Height="14"
                                  Foreground="#4C97FF"/>
                        <TextBlock Text="Center"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="toolBtn"
                        ToolTip.Tip="Fit active item to view"
                        Click="FitActiveItem_OnClick"
                        IsVisible="{Binding ActiveItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M3,3H9V5H5V9H3V3M21,3V9H19V5H15V3H21M3,21V15H5V19H9V21H3M21,21H15V19H19V15H21V21Z"
                                  Width="14"
                                  Height="14"
                                  Foreground="#4C97FF"/>
                        <TextBlock Text="Fit"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="toolBtn"
                        ToolTip.Tip="Center selected items in view"
                        Click="CenterSelection_OnClick"
                        IsVisible="{Binding HasSelection}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M12,2L15,9H22L16.5,13.5L18.5,21L12,16.5L5.5,21L7.5,13.5L2,9H9L12,2Z"
                                  Width="14"
                                  Height="14"
                                  Foreground="#4C97FF"/>
                        <TextBlock Text="Center Sel"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="toolBtn"
                        ToolTip.Tip="Fit selected items to view"
                        Click="FitSelection_OnClick"
                        IsVisible="{Binding HasSelection}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M4,4H9V6H6V9H4V4M20,4V9H18V6H15V4H20M4,20V15H6V18H9V20H4M20,20H15V18H18V15H20V20M9,9H15V15H9V9Z"
                                  Width="14"
                                  Height="14"
                                  Foreground="#4C97FF"/>
                        <TextBlock Text="Fit Sel"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,18,18"
                Padding="14,12"
                Background="#D9121418"
                BorderBrush="#3A414D"
                BorderThickness="1"
                CornerRadius="10"
                Width="380"
                BoxShadow="0 10 24 0 #66000000">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="Жесты редактора"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Classes="toolBtn"
                            Command="{Binding ToggleGestureHelpCommand}"
                            Padding="4"
                            ToolTip.Tip="Свернуть подсказки"
                            IsVisible="{Binding IsGestureHelpExpanded}">
                        <PathIcon Data="M7,10L12,15L17,10H7Z"
                                  Width="12"
                                  Height="12"
                                  Foreground="#A9D1FF"/>
                    </Button>

                    <Button Grid.Column="1"
                            Classes="toolBtn"
                            Command="{Binding ToggleGestureHelpCommand}"
                            Padding="4"
                            ToolTip.Tip="Развернуть подсказки"
                            IsVisible="{Binding IsGestureHelpCollapsed}">
                        <PathIcon Data="M10,7L15,12L10,17V7Z"
                                  Width="12"
                                  Height="12"
                                  Foreground="#A9D1FF"/>
                    </Button>
                </Grid>

                <Grid IsVisible="{Binding IsGestureHelpExpanded}"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="6">
                    <Border Grid.Row="0"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Left Click"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="Выбрать вложенный контрол"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="1"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Shift + Click"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="Добавить вложенный контрол в той же форме"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="2"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Left Drag"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="Тянуть выделение или рамку по пустой области"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="3"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Middle Drag"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Text="Панорамирование viewport"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="4"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Wheel"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="Масштабирование viewport"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="5"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Ctrl + Click"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="5"
                               Grid.Column="1"
                               Text="Выбрать DesignEditorItem"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="6"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Ctrl + Drag"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="6"
                               Grid.Column="1"
                               Text="Переместить выбранный DesignEditorItem"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="7"
                            Background="#243246"
                            CornerRadius="4"
                            Padding="6,2">
                        <TextBlock Text="Ctrl + Shift"
                                   Foreground="#A9D1FF"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="7"
                               Grid.Column="1"
                               Text="Добавить item или рамочное выделение контейнеров"
                               Foreground="#C9D1D9"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                </Grid>

                <TextBlock IsVisible="{Binding IsGestureHelpCollapsed}"
                           Text="Показать подсказки"
                           Foreground="#A9D1FF"
                           FontSize="10"
                           Opacity="0.9"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
