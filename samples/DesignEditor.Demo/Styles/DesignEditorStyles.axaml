<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesignEditor.Demo.ViewModels"
        xmlns:design="clr-namespace:ArxisStudio;assembly=ArxisStudio.DesignEditor">

    <Style Selector="design|DesignEditorItem" x:DataType="vm:DesignItemViewModel">
        <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}" />
        <Setter Property="Width" Value="{Binding Width, Mode=TwoWay}" />
        <Setter Property="Height" Value="{Binding Height, Mode=TwoWay}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="#F0171B22" />
        <Setter Property="BorderBrush" Value="#3E4655" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="#DCE6F8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover">
        <Setter Property="Background" Value="#2B3750" />
        <Setter Property="Foreground" Value="#DCE6F8" />
    </Style>

    <Style Selector="ContextMenu MenuItem:pressed">
        <Setter Property="Background" Value="#324564" />
        <Setter Property="Foreground" Value="#F5F9FF" />
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F5F9FF" />
    </Style>

    <Style Selector="ContextMenu MenuItem:pressed /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F5F9FF" />
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Margin" Value="4,6" />
        <Setter Property="Background" Value="#334054" />
    </Style>
</Styles>
